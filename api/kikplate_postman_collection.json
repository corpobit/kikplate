{
  "info": {
    "name": "Kickplate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "verification_token", "value": "" },
    { "key": "plate_id", "value": "" },
    { "key": "plate_slug", "value": "" },
    { "key": "org_id", "value": "" }
  ],
  "item": [
    {
      "name": "Hello",
      "item": [
        {
          "name": "Hello",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/hello",
              "host": ["{{base_url}}"],
              "path": ["hello"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"moeidheidari\",\n  \"email\": \"moe@example.com\",\n  \"password\": \"strongpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/verify-email?token={{verification_token}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{verification_token}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"moe@example.com\",\n  \"password\": \"strongpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Providers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/providers",
              "host": ["{{base_url}}"],
              "path": ["auth", "providers"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me/profile",
              "host": ["{{base_url}}"],
              "path": ["me", "profile"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Moe\",\n  \"avatar_url\": \"https://example.com/avatar.png\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Set Username",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me/username",
              "host": ["{{base_url}}"],
              "path": ["me", "username"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"moeidheidari\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "OAuth Redirect (GitHub)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/github/redirect",
              "host": ["{{base_url}}"],
              "path": ["auth", "github", "redirect"]
            }
          }
        }
      ]
    },
    {
      "name": "Badges",
      "item": [
        {
          "name": "List Badges",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/badges",
              "host": ["{{base_url}}"],
              "path": ["badges"]
            }
          }
        }
      ]
    },
    {
      "name": "Organizations",
      "item": [
        {
          "name": "List Public Organizations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/organizations?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["organizations"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/organizations",
              "host": ["{{base_url}}"],
              "path": ["organizations"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"kickplate-core\",\n  \"description\": \"Core platform team\",\n  \"logo_url\": \"https://example.com/logo.png\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('org_id', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Organizations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/organizations/me",
              "host": ["{{base_url}}"],
              "path": ["organizations", "me"]
            }
          }
        },
        {
          "name": "Get Organization By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/organizations/{{org_id}}",
              "host": ["{{base_url}}"],
              "path": ["organizations", "{{org_id}}"]
            }
          }
        },
        {
          "name": "Get Organization By Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/organizations/by-name/kickplate-core",
              "host": ["{{base_url}}"],
              "path": ["organizations", "by-name", "kickplate-core"]
            }
          }
        },
        {
          "name": "Update Organization",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/organizations/{{org_id}}",
              "host": ["{{base_url}}"],
              "path": ["organizations", "{{org_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Organization",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/organizations/{{org_id}}",
              "host": ["{{base_url}}"],
              "path": ["organizations", "{{org_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Plates",
      "item": [
        {
          "name": "List Plates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/plates?search=go&categories=backend,devops&tags=docker,grpc&page=1&limit=24",
              "host": ["{{base_url}}"],
              "path": ["plates"],
              "query": [
                { "key": "search", "value": "go" },
                { "key": "categories", "value": "backend,devops" },
                { "key": "tags", "value": "docker,grpc" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "24" }
              ]
            }
          }
        },
        {
          "name": "List Plates - Owner",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates?owner_id={{account_id}}&limit=48",
              "host": ["{{base_url}}"],
              "path": ["plates"],
              "query": [
                { "key": "owner_id", "value": "{{account_id}}" },
                { "key": "limit", "value": "48" }
              ]
            }
          }
        },
        {
          "name": "List Bookmarked Plates",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/bookmarked?limit=48",
              "host": ["{{base_url}}"],
              "path": ["plates", "bookmarked"],
              "query": [
                { "key": "limit", "value": "48" }
              ]
            }
          }
        },
        {
          "name": "Plate Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/plates/stats",
              "host": ["{{base_url}}"],
              "path": ["plates", "stats"]
            }
          }
        },
        {
          "name": "Plate Filter Options",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/plates/filters",
              "host": ["{{base_url}}"],
              "path": ["plates", "filters"]
            }
          }
        },
        {
          "name": "Submit Repository Plate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/repository",
              "host": ["{{base_url}}"],
              "path": ["plates", "repository"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repo_url\": \"https://github.com/MoeidHeidari/dummy-boilerplate\",\n  \"branch\": \"main\",\n  \"organization_id\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('plate_id', body.id);",
                  "  if (body.slug) pm.collectionVariables.set('plate_slug', body.slug);",
                  "  if (body.verification_token) pm.collectionVariables.set('verification_token', body.verification_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Repository Plate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/verify",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "verify"]
            }
          }
        },
        {
          "name": "Get Plate By Slug",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_slug}}",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_slug}}"]
            }
          }
        },
        {
          "name": "Update Plate",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\",\n  \"visibility\": \"public\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Move Plate To Organization",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/organization",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "organization"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_id\": \"{{org_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Replace Tags",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/tags",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "tags"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tags\": [\"go\", \"grpc\", \"docker\"]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Set Bookmark",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/bookmark",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "bookmark"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookmarked\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/reviews",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "reviews"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"title\": \"Great starter\",\n  \"body\": \"Solid baseline and docs\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Approve Plate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Plate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "reject"]
            }
          }
        },
        {
          "name": "Grant Badge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/badges",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "badges"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"badge_slug\": \"featured\",\n  \"reason\": \"Excellent quality\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Revoke Badge",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/badges/featured",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "badges", "featured"]
            }
          }
        },
        {
          "name": "Archive Plate",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}"]
            }
          }
        },
        {
          "name": "Remove Plate (Hard Delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plates/{{plate_id}}/remove",
              "host": ["{{base_url}}"],
              "path": ["plates", "{{plate_id}}", "remove"]
            }
          }
        }
      ]
    }
  ]
}
